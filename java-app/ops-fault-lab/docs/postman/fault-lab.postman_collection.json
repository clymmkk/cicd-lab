      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/scenarios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "scenarios"
          ]
        }
      }
    },
    {
