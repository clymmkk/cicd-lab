      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"operator\": \"ops_user\",\n  \"extras\": {\n    \"blocks\": 16\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/scenarios/heap-oom/trigger",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "scenarios",
            "heap-oom",
            "trigger"
          ]
        }
      }
    },
    {
      "name": "Stop Heap OOM",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"operator\": \"ops_user\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/scenarios/heap-oom/stop",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
